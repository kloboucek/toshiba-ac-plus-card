{
  "name": "toshiba-ac-plus-card",
  "version": "0.2.6",
  "description": "A Home Assistant Lovelace card for Toshiba AC extra controls and off-timer support.",
  "type": "module",
  "scripts": {
    "build": "tsc && esbuild src/toshiba-ac-plus-card.ts --bundle --format=esm --target=es2022 --outfile=toshiba-ac-plus-card.js",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "hacs",
    "toshiba",
    "climate"
  ],
  "author": "kloboucek",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.3"
  }
}
